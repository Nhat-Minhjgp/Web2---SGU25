<file path="B01/view/checkout.php">
<?php
/**
 * Checkout Page - NVBPlay Style
 * Render cart từ session + Lưu order vào database với trạng thái "Chờ xác nhận"
 */
session_start();
require_once '../control/connect.php';

// === KIỂM TRA ĐĂNG NHẬP ===
if (!isset($_SESSION['user_id']) || ($_SESSION['role'] ?? 0) != 0) {
    header("Location: login.php?redirect=checkout");
    exit();
}

$user_id = (int) $_SESSION['user_id'];
$success = '';
$errors = [];

// === LẤY ĐỊA CHỈ MẶC ĐỊNH ===
$default_address = null;
$stmt = $conn->prepare("SELECT * FROM diachigh WHERE User_id = ? AND Mac_dinh = 1 LIMIT 1");
$stmt->bind_param("i", $user_id);
$stmt->execute();
$result = $stmt->get_result();
if ($result->num_rows > 0) {
    $default_address = $result->fetch_assoc();
}
$stmt->close();

// === LẤY GIỎ HÀNG TỪ SESSION ===
$cart_items = [];
$cart_total = 0;
$total_items = 0;

if (!empty($_SESSION['cart']) && is_array($_SESSION['cart'])) {
    $product_ids = array_keys($_SESSION['cart']);
    $placeholders = implode(',', array_fill(0, count($product_ids), '?'));
    
    $stmt = $conn->prepare("SELECT SanPham_id, TenSP, GiaBan, image_url 
                           FROM sanpham 
                           WHERE SanPham_id IN ($placeholders) AND TrangThai = 1");
    $types = str_repeat('i', count($product_ids));
    $stmt->bind_param($types, ...$product_ids);
    $stmt->execute();
    $products = $stmt->get_result();
    
    while ($product = $products->fetch_assoc()) {
        $qty = $_SESSION['cart'][$product['SanPham_id']] ?? 1;
        $product['quantity'] = $qty;
        $product['subtotal'] = $product['GiaBan'] * $qty;
        $cart_total += $product['subtotal'];
        $total_items += $qty;
        $cart_items[] = $product;
    }
    $stmt->close();
}


$order_total = $cart_total;

// === XỬ LÝ ĐẶT HÀNG ===
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['place_order'])) {
    
    // Validation cơ bản
    if (empty($cart_items)) {
        $errors[] = "Giỏ hàng của bạn đang trống";
    }
    
    $payment_method = $_POST['payment_method'] ?? 'cod';
    
    // Validation thông tin giao hàng
    $fullname = trim(htmlspecialchars($_POST['fullname'] ?? ''));
    $phone = trim(preg_replace('/[^0-9]/', '', $_POST['phone'] ?? ''));
    $address = trim(htmlspecialchars($_POST['address'] ?? ''));
    
    if (empty($fullname) || mb_strlen($fullname) < 2) {
        $errors[] = "Vui lòng nhập họ tên hợp lệ";
    }
    if (!preg_match('/^0[0-9]{9}$/', $phone)) {
        $errors[] = "Số điện thoại không hợp lệ (bắt đầu bằng 0, 10 số)";
    }
    if (empty($address) || mb_strlen($address) < 10) {
        $errors[] = "Vui lòng nhập địa chỉ chi tiết";
    }
    
    if (empty($errors)) {
        // Generate tracking code unique
        $tracking_code = 'NVB' . date('Ymd') . strtoupper(substr(md5(uniqid($user_id . time(), true)), 0, 8));
        $link_tra_cuu = '/view/track-order.php?code=' . $tracking_code;
        
        // INSERT vào DonHang với Prepared Statement - CHỐNG SQL INJECTION
        // Trạng thái: "Chờ xác nhận"
        $stmt = $conn->prepare("INSERT INTO DonHang (User_id, DiaChi_id, PhuongThucTT, TongTien, NgayDat, TrangThai, linkTraCuu) VALUES (?, ?, ?, ?, CURDATE(), ?, ?)");
        
        $dia_chi_id = !empty($_POST['selected_address_id']) ? (int) $_POST['selected_address_id'] : null;
        $trang_thai = 'Chờ xác nhận'; 
        
        $stmt->bind_param("iisiss", $user_id, $dia_chi_id, $payment_method, $order_total, $trang_thai, $link_tra_cuu);
        
        if ($stmt->execute()) {
            $don_hang_id = $stmt->insert_id;
            $stmt->close();
            
            //  Lưu chi tiết đơn hàng vào DonHang_ChiTiet (nếu có table này)
            if (tableExists($conn, 'DonHang_ChiTiet')) {
                $stmt_detail = $conn->prepare("INSERT INTO DonHang_ChiTiet (DonHang_id, SanPham_id, SoLuong, DonGia) VALUES (?, ?, ?, ?)");
                foreach ($cart_items as $item) {
                    $stmt_detail->bind_param("iiid", $don_hang_id, $item['SanPham_id'], $item['quantity'], $item['GiaBan']);
                    $stmt_detail->execute();
                }
                $stmt_detail->close();
            }
            
            //  Lưu thông tin người nhận khác nếu có
            if (!empty($_POST['someoneReceive'])) {
                $recipient_name = trim(htmlspecialchars($_POST['recipient_name'] ?? ''));
                $recipient_phone = trim(preg_replace('/[^0-9]/', '', $_POST['recipient_phone'] ?? ''));
                
                if (!empty($recipient_name) && !empty($recipient_phone)) {
                    $_SESSION['last_order_recipient'] = [
                        'name' => $recipient_name,
                        'phone' => $recipient_phone
                    ];
                }
            }
            
            //  Clear cart session sau khi đặt hàng thành công
            unset($_SESSION['cart']);
            
            //  REDIRECT VỀ TRANG LỊCH SỬ ĐƠN HÀNG
            header("Location: ./my-account/orders.php?order_id=" . $don_hang_id . "&success=1");
            exit();
            
        } else {
            $errors[] = "Lỗi hệ thống: " . $conn->error;
            $stmt->close();
        }
    }
}

// Helper function to check if table exists
function tableExists($conn, $table_name) {
    $result = $conn->query("SHOW TABLES LIKE '$table_name'");
    return $result && $result->num_rows > 0;
}

// Format giá
function formatPrice($price) {
    return number_format($price, 0, ',', '.') . '₫';
}

// Lấy thông tin user cho header
$user_info = [
    'username' => $_SESSION['username'] ?? '',
    'ho_ten' => $_SESSION['ho_ten'] ?? '',
    'email' => $_SESSION['email'] ?? '',
    'phone' => $_SESSION['phone'] ?? ''
];

// Build full address from default address
$default_full_address = '';
if ($default_address) {
    $parts = array_filter([
        $default_address['Duong'],
        $default_address['Quan'],
        $default_address['Tinh_thanhpho'],
        $default_address['Dia_chi_chitiet']
    ]);
    $default_full_address = implode(', ', $parts);
}
?>
